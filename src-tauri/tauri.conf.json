{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShaderTester",
  "version": "0.1.0",
  "identifier": "com.bc2017.shadertester",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShaderTester",
        "width": 1440,
        "height": 920,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
